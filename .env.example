# ============================================================
#  Vaultify — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env to version control!
# ============================================================

# ── MySQL Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=jana
DB_NAME=vaultify

# ── JWT Auth ────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=0a3707fceb80eb41fdcc68b91df5cf86faa5810a485ed26a9f328e562eb19663

# Token expiry in hours (default 24)
JWT_EXPIRY_HOURS=24

# ── Fernet Encryption Key ───────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=EqB5zRdEK9pyVIqUJx7Ir5aZI5xnDKiyrv281Q3hCZg=

# ── Flask ───────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
